{
  "name": "celsium",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/forgesync run dev",
    "build:web": "npm --workspace apps/forgesync run build",
    "dev:cli": "npm --workspace packages/forgesync-cli run dev"
  }
}